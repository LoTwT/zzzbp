    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.0",
    "tailwindcss": "^4.1.11",
    "taze": "^19.1.0",
    "vue-router": "latest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
